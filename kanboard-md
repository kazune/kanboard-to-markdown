#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat >&2 <<EOF
Usage:
  $0 boards
  $0 board <board_id>
  $0 task <task_id>
EOF
}

COMMAND=${1:-}
RESOURCE_ID=

case "$COMMAND" in
  boards)
    if [[ $# -ne 1 ]]; then
      usage
      exit 1
    fi
    ;;
  board | task)
    if [[ $# -ne 2 || ! "$2" =~ ^[1-9][0-9]*$ ]]; then
      usage
      exit 1
    fi
    RESOURCE_ID=$2
    ;;
  *)
    usage
    exit 1
    ;;
esac

CONFIG_FILE=
CONFIG_STATUS="未確認"
CONFIG_SOURCE="決定できず"
ENV_URL_STATUS="未設定"
ENV_USERNAME_STATUS="未設定"
ENV_TOKEN_STATUS="未設定"
ENV_CONFIG_STATUS="未設定"
ENV_XDG_STATUS="未設定"
ENV_HOME_STATUS="未設定"

config_file_mode() {
  local file=$1
  local mode=

  if mode=$(stat -L -f '%Lp' "$file" 2>/dev/null) && [[ "$mode" =~ ^[0-7]{3,4}$ ]]; then
    printf '%s\n' "$mode"
    return
  fi

  if mode=$(stat -L -c '%a' "$file" 2>/dev/null) && [[ "$mode" =~ ^[0-7]{3,4}$ ]]; then
    printf '%s\n' "$mode"
    return
  fi

  return 1
}

check_config_permissions() {
  local file=$1
  local mode=

  if ! mode=$(config_file_mode "$file"); then
    CONFIG_STATUS="権限を確認できず"
    echo "Error: could not determine config file permissions: $file" >&2
    exit 1
  fi

  if [[ "${mode: -2}" != "00" ]]; then
    CONFIG_STATUS="安全でないパーミッション（${mode}）"
    echo "Error: insecure config file permissions: $file (mode $mode)" >&2
    echo "Remove all permissions for group and others, for example: chmod 600 '$file'" >&2
    exit 1
  fi
}

load_config() {
  local config_home=
  local saved_url=${KANBOARD_URL:-}
  local saved_username=${KANBOARD_USERNAME:-}
  local saved_token=${KANBOARD_API_TOKEN:-}

  if [[ -n "${KANBOARD_MD_CONFIG:-}" ]]; then
    ENV_CONFIG_STATUS="設定済み"
  fi
  if [[ -n "${XDG_CONFIG_HOME:-}" ]]; then
    ENV_XDG_STATUS="設定済み"
  fi
  if [[ -n "${HOME:-}" ]]; then
    ENV_HOME_STATUS="設定済み"
  fi

  if [[ -n "$saved_url" ]]; then
    ENV_URL_STATUS="設定済み"
  fi
  if [[ -n "$saved_username" ]]; then
    ENV_USERNAME_STATUS="設定済み"
  fi
  if [[ -n "$saved_token" ]]; then
    ENV_TOKEN_STATUS="設定済み"
  fi

  if [[ -n "$saved_url" && -n "$saved_username" && -n "$saved_token" ]]; then
    CONFIG_STATUS="不要（必要な環境変数はすべて設定済み）"
    return
  fi

  if [[ -n "${KANBOARD_MD_CONFIG:-}" ]]; then
    CONFIG_FILE=$KANBOARD_MD_CONFIG
    CONFIG_SOURCE="KANBOARD_MD_CONFIG"
  elif [[ -n "${XDG_CONFIG_HOME:-}" ]]; then
    config_home=$XDG_CONFIG_HOME
    CONFIG_FILE="$config_home/kanboard-md/config.env"
    CONFIG_SOURCE="XDG_CONFIG_HOME"
  elif [[ -n "${HOME:-}" ]]; then
    config_home="$HOME/.config"
    CONFIG_FILE="$config_home/kanboard-md/config.env"
    CONFIG_SOURCE="HOME"
  else
    CONFIG_SOURCE="決定できず"
  fi

  if [[ -z "$CONFIG_FILE" ]]; then
    CONFIG_STATUS="探索不可（XDG_CONFIG_HOME と HOME が未設定）"
  elif [[ -f "$CONFIG_FILE" ]]; then
    check_config_permissions "$CONFIG_FILE"
    set -a
    # shellcheck disable=SC1090
    source "$CONFIG_FILE"
    set +a
    CONFIG_STATUS="読込済み"
  else
    CONFIG_STATUS="ファイルなし"
  fi

  # 直接指定された環境変数を設定ファイルの値より優先する。
  if [[ -n "$saved_url" ]]; then
    KANBOARD_URL=$saved_url
  fi
  if [[ -n "$saved_username" ]]; then
    KANBOARD_USERNAME=$saved_username
  fi
  if [[ -n "$saved_token" ]]; then
    KANBOARD_API_TOKEN=$saved_token
  fi
}

load_config

require_config() {
  local missing=()

  if [[ -z "${KANBOARD_URL:-}" ]]; then
    missing+=("KANBOARD_URL")
  fi
  if [[ -z "${KANBOARD_USERNAME:-}" ]]; then
    missing+=("KANBOARD_USERNAME")
  fi
  if [[ -z "${KANBOARD_API_TOKEN:-}" ]]; then
    missing+=("KANBOARD_API_TOKEN")
  fi

  if [[ ${#missing[@]} -eq 0 ]]; then
    return
  fi

  echo "Error: required configuration is missing: ${missing[*]}" >&2
  echo "確認した設定:" >&2
  echo "  環境変数 KANBOARD_URL: $ENV_URL_STATUS" >&2
  echo "  環境変数 KANBOARD_USERNAME: $ENV_USERNAME_STATUS" >&2
  echo "  環境変数 KANBOARD_API_TOKEN: $ENV_TOKEN_STATUS" >&2
  echo "  探索用環境変数 KANBOARD_MD_CONFIG: $ENV_CONFIG_STATUS" >&2
  echo "  探索用環境変数 XDG_CONFIG_HOME: $ENV_XDG_STATUS" >&2
  echo "  探索用環境変数 HOME: $ENV_HOME_STATUS" >&2
  if [[ -n "$CONFIG_FILE" ]]; then
    echo "  設定ファイル $CONFIG_FILE: ${CONFIG_STATUS}（${CONFIG_SOURCE} から決定）" >&2
  else
    echo "  設定ファイル: $CONFIG_STATUS" >&2
  fi
  exit 1
}

require_config

for command_name in curl jq; do
  if ! command -v "$command_name" >/dev/null 2>&1; then
    echo "Error: $command_name is required." >&2
    exit 1
  fi
done

TMP_DIR=$(mktemp -d "${TMPDIR:-/tmp}/kanboard-md.XXXXXX")
trap 'rm -rf "$TMP_DIR"' EXIT

rpc() {
  local method=$1
  local params=$2
  local destination=$3
  local request_file="$TMP_DIR/request.json"
  local response_file="$TMP_DIR/response.json"

  jq -n \
    --arg method "$method" \
    --argjson params "$params" \
    '{jsonrpc: "2.0", method: $method, id: 1, params: $params}' \
    >"$request_file"

  curl -fsS \
    -u "$KANBOARD_USERNAME:$KANBOARD_API_TOKEN" \
    -H "Content-Type: application/json" \
    --data-binary "@$request_file" \
    "${KANBOARD_URL%/}/jsonrpc.php" \
    >"$response_file"

  if ! jq -e 'has("result") and (.error == null)' "$response_file" >/dev/null; then
    echo "Kanboard API error in $method:" >&2
    jq -r 'if .error then (.error.message // (.error | tostring)) else "Invalid JSON-RPC response" end' \
      "$response_file" >&2
    exit 1
  fi

  jq '.result' "$response_file" >"$destination"
}

export_boards() {
  local method=getMyProjects

  if [[ "$KANBOARD_USERNAME" == "jsonrpc" ]]; then
    method=getAllProjects
  fi

  rpc "$method" '{}' "$TMP_DIR/projects.json"

  jq -nr \
    --slurpfile projects "$TMP_DIR/projects.json" '
      def text:
        if . == null then "" else tostring | gsub("[\\r\\n]+"; " ") end;

      def items:
        if type == "array" then . else [] end;

      def board_link:
        "- #" + (.id | text) + " " +
        (if (.url.board // "") != "" then
          "[" + (.name | text) + "](" + .url.board + ")"
         else .name | text end) +
        (if (.identifier // "") != "" then " (`" + (.identifier | text) + "`)" else "" end);

      ($projects[0] | items | sort_by(.id | tonumber)) as $all |
      ([$all[] | select((.is_active | tostring) == "1")]) as $active |
      ([$all[] | select((.is_active | tostring) != "1")]) as $inactive |

      "# Boards",
      "",
      "## 有効 (" + ($active | length | tostring) + ")",
      "",
      (if ($active | length) == 0 then "_ボードなし_" else ($active[] | board_link) end),
      "",
      "## 無効 (" + ($inactive | length | tostring) + ")",
      "",
      (if ($inactive | length) == 0 then "_ボードなし_" else ($inactive[] | board_link) end),
      ""
    '
}

export_board() {
  local board_id=$1
  local params

  params=$(jq -cn --argjson project_id "$board_id" '{project_id: $project_id}')
  rpc "getProjectById" "$params" "$TMP_DIR/project.json"
  rpc "getBoard" "$params" "$TMP_DIR/board.json"

  jq -nr \
    --slurpfile project "$TMP_DIR/project.json" \
    --slurpfile board "$TMP_DIR/board.json" '
      def text:
        if . == null then "" else tostring | gsub("[\\r\\n]+"; " ") end;

      def due_date:
        if . == null or . == "" or . == 0 or . == "0" then null
        elif type == "number" then strftime("%Y-%m-%d")
        elif test("^[0-9]+$") then tonumber | strftime("%Y-%m-%d")
        else text
        end;

      ($project[0]) as $p |
      ($board[0]) as $swimlanes |

      "# " + ($p.name | text),
      "",
      "- プロジェクトID: " + ($p.id | text),
      "- 状態: " + (if ($p.is_active | tostring) == "1" then "有効" else "無効" end),
      (if ($p.description // "") != "" then
        "- 説明: " + ($p.description | text)
       else empty end),
      "",
      ($swimlanes[] |
        . as $swimlane |
        "## " + ($swimlane.name | text),
        "",
        ($swimlane.columns | sort_by(.position | tonumber)[] |
          . as $column |
          (($column.tasks // []) | sort_by(.position | tonumber)) as $column_tasks |
          "### " + ($column.title | text) + " (" + ($column_tasks | length | tostring) + ")",
          (if (($column.task_limit // 0) | tonumber) > 0 then
            "",
            "タスク上限: " + ($column.task_limit | text)
           else empty end),
          "",
          (if ($column_tasks | length) == 0 then
            "_タスクなし_"
           else
            ($column_tasks[] |
              . as $task |
              ([
                (if ($task.assignee_name // "") != "" then "担当: " + ($task.assignee_name | text)
                 elif ($task.assignee_username // "") != "" then "担当: " + ($task.assignee_username | text)
                 else "担当: 未割り当て" end),
                (if ($task.category_name // "") != "" then "カテゴリ: " + ($task.category_name | text) else empty end),
                (($task.date_due | due_date) as $due | if $due then "期限: " + $due else empty end),
                (if ($task.score // 0 | tonumber) > 0 then "複雑度: " + ($task.score | text) else empty end)
              ] | join(" / ")) as $meta |
              "- #" + ($task.id | text) + " " + ($task.title | text) +
              (if $meta != "" then " — " + $meta else "" end)
            )
          end),
          ""
        )
      )
    '
}

export_task() {
  local task_id=$1
  local task_params
  local project_id
  local project_params

  task_params=$(jq -cn --argjson task_id "$task_id" '{task_id: $task_id}')
  rpc "getTask" "$task_params" "$TMP_DIR/task.json"

  if ! jq -e 'type == "object"' "$TMP_DIR/task.json" >/dev/null; then
    echo "Error: task $task_id was not found." >&2
    exit 1
  fi

  project_id=$(jq -r '.project_id' "$TMP_DIR/task.json")
  project_params=$(jq -cn --argjson project_id "$project_id" '{project_id: $project_id}')

  rpc "getProjectById" "$project_params" "$TMP_DIR/project.json"
  rpc "getBoard" "$project_params" "$TMP_DIR/board.json"
  rpc "getAllSubtasks" "$task_params" "$TMP_DIR/subtasks.json"
  rpc "getAllComments" "$task_params" "$TMP_DIR/comments.json"

  jq -nr \
    --arg task_id "$task_id" \
    --slurpfile task "$TMP_DIR/task.json" \
    --slurpfile project "$TMP_DIR/project.json" \
    --slurpfile board "$TMP_DIR/board.json" \
    --slurpfile subtasks "$TMP_DIR/subtasks.json" \
    --slurpfile comments "$TMP_DIR/comments.json" '
      def text:
        if . == null then "" else tostring | gsub("[\\r\\n]+"; " ") end;

      def markdown:
        if . == null then "" else tostring | gsub("\\r\\n"; "\n") | gsub("\\r"; "\n") end;

      def present:
        . != null and . != "" and . != 0 and . != "0";

      def timestamp:
        if present then tonumber | strftime("%Y-%m-%d %H:%M UTC") else null end;

      def items:
        if type == "array" then . else [] end;

      ($task[0]) as $t |
      ($project[0]) as $p |
      ($subtasks[0] | items | sort_by(.position // .id | tonumber)) as $sts |
      ($comments[0] | items | sort_by(.date_creation | tonumber)) as $cs |
      ([
        $board[0][] as $swimlane |
        $swimlane.columns[] as $column |
        ($column.tasks // [])[] |
        select((.id | tostring) == $task_id) |
        . + {
          swimlane_name: $swimlane.name,
          column_name: $column.title
        }
      ] | first // {}) as $board_task |

      "# #" + ($t.id | text) + " " + ($t.title | text),
      "",
      "- 状態: " + (if ($t.is_active | tostring) == "1" then "有効" else "完了" end),
      "- プロジェクト: " + ($p.name // ("ID: " + ($t.project_id | text)) | text),
      "- スイムレーン: " +
        (if ($board_task.swimlane_name // "") != "" then $board_task.swimlane_name
         elif ($t.swimlane_id | tostring) == "0" then ($p.default_swimlane // "Default swimlane")
         else "ID: " + ($t.swimlane_id | text) end),
      "- 列: " + ($board_task.column_name // ("ID: " + ($t.column_id | text)) | text),
      "- 担当: " +
        (if ($board_task.assignee_name // "") != "" then ($board_task.assignee_name | text)
         elif ($board_task.assignee_username // "") != "" then ($board_task.assignee_username | text)
         elif ($t.owner_id | tostring) == "0" then "未割り当て"
         else "ユーザーID: " + ($t.owner_id | text) end),
      (if ($board_task.category_name // "") != "" then
        "- カテゴリ: " + ($board_task.category_name | text)
       elif ($t.category_id | tostring) != "0" then
        "- カテゴリID: " + ($t.category_id | text)
       else empty end),
      (if ($t.reference // "") != "" then "- 参照: " + ($t.reference | text) else empty end),
      (if ($t.priority // 0 | tonumber) > 0 then "- 優先度: " + ($t.priority | text) else empty end),
      (if ($t.score // 0 | tonumber) > 0 then "- 複雑度: " + ($t.score | text) else empty end),
      (if ($t.time_estimated // 0 | tonumber) > 0 then "- 見積時間: " + ($t.time_estimated | text) + "h" else empty end),
      (if ($t.time_spent // 0 | tonumber) > 0 then "- 作業時間: " + ($t.time_spent | text) + "h" else empty end),
      (($t.date_creation | timestamp) as $date | if $date then "- 作成: " + $date else empty end),
      (($t.date_started | timestamp) as $date | if $date then "- 開始: " + $date else empty end),
      (($t.date_due | timestamp) as $date | if $date then "- 期限: " + $date else empty end),
      (($t.date_completed | timestamp) as $date | if $date then "- 完了: " + $date else empty end),
      (if ($t.url // "") != "" then "- URL: " + $t.url else empty end),
      "",
      "## 説明",
      "",
      (if ($t.description // "") != "" then ($t.description | markdown) else "_説明なし_" end),
      "",
      "## サブタスク",
      "",
      (if ($sts | length) == 0 then
        "_サブタスクなし_"
       else
        ($sts[] |
          "- [" + (if (.status | tostring) == "2" then "x" else " " end) + "] " + (.title | text) +
          (if (.status | tostring) == "1" then "（進行中）" else "" end) +
          (if (.name // "") != "" then " — 担当: " + (.name | text)
           elif (.username // "") != "" then " — 担当: " + (.username | text)
           else "" end)
        )
      end),
      "",
      "## コメント",
      "",
      (if ($cs | length) == 0 then
        "_コメントなし_"
       else
        ($cs[] |
          "### " +
            (if (.name // "") != "" then (.name | text)
             elif (.username // "") != "" then (.username | text)
             else "不明なユーザー" end) +
            ((.date_creation | timestamp) as $date | if $date then " — " + $date else "" end),
          "",
          (.comment | markdown),
          ""
        )
      end)
    '
}

case "$COMMAND" in
  boards) export_boards ;;
  board) export_board "$RESOURCE_ID" ;;
  task) export_task "$RESOURCE_ID" ;;
esac
