#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat >&2 <<EOF
Usage:
  $0 --config <file> boards
  $0 --config <file> board <board_id>
  $0 --config <file> task <task_id>
EOF
}

if [[ ${1:-} != "--config" || -z ${2:-} ]]; then
  usage
  exit 1
fi

CONFIG_FILE=$2
shift 2

COMMAND=${1:-}
RESOURCE_ID=

case "$COMMAND" in
  boards)
    if [[ $# -ne 1 ]]; then
      usage
      exit 1
    fi
    ;;
  board | task)
    if [[ $# -ne 2 || ! "$2" =~ ^[1-9][0-9]*$ ]]; then
      usage
      exit 1
    fi
    RESOURCE_ID=$2
    ;;
  *)
    usage
    exit 1
    ;;
esac

if ! command -v jq >/dev/null 2>&1; then
  echo "Error: jq is required." >&2
  exit 1
fi

config_file_mode() {
  local file=$1
  local mode=

  if mode=$(stat -L -f '%Lp' "$file" 2>/dev/null) && [[ "$mode" =~ ^[0-7]{3,4}$ ]]; then
    printf '%s\n' "$mode"
    return
  fi

  if mode=$(stat -L -c '%a' "$file" 2>/dev/null) && [[ "$mode" =~ ^[0-7]{3,4}$ ]]; then
    printf '%s\n' "$mode"
    return
  fi

  return 1
}

config_file_uid() {
  local file=$1
  local uid=

  if uid=$(stat -L -f '%u' "$file" 2>/dev/null) && [[ "$uid" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$uid"
    return
  fi

  if uid=$(stat -L -c '%u' "$file" 2>/dev/null) && [[ "$uid" =~ ^[0-9]+$ ]]; then
    printf '%s\n' "$uid"
    return
  fi

  return 1
}

check_config_permissions() {
  local file=$1
  local display_file=${2:-$file}
  local mode=
  local owner_uid=
  local current_uid=

  if ! mode=$(config_file_mode "$file"); then
    echo "Error: could not determine config file permissions: $display_file" >&2
    exit 1
  fi

  if [[ "${mode: -2}" != "00" ]]; then
    echo "Error: insecure config file permissions: $display_file (mode $mode)" >&2
    echo "Remove all permissions for group and others, for example: chmod 600 '$display_file'" >&2
    exit 1
  fi

  if ! owner_uid=$(config_file_uid "$file") || ! current_uid=$(id -u); then
    echo "Error: could not determine config file owner: $display_file" >&2
    exit 1
  fi

  if [[ "$owner_uid" != "$current_uid" ]]; then
    echo "Error: config file must be owned by the current user: $display_file" >&2
    exit 1
  fi
}

load_config() {
  local config_json=

  if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: config file not found: $CONFIG_FILE" >&2
    exit 1
  fi

  if ! exec 9<"$CONFIG_FILE"; then
    echo "Error: could not open config file: $CONFIG_FILE" >&2
    exit 1
  fi

  check_config_permissions /dev/fd/9 "$CONFIG_FILE"

  if ! config_json=$(jq -ce '
    if type == "object" and
       (.url | type == "string" and length > 0) and
       (.username | type == "string" and length > 0) and
       (.apiToken | type == "string" and length > 0)
    then {url, username, apiToken}
    else error("url, username, and apiToken must be non-empty strings")
    end
  ' /dev/fd/9); then
    echo "Error: invalid config file: $CONFIG_FILE" >&2
    exit 1
  fi
  exec 9<&-

  KANBOARD_URL=$(jq -r '.url' <<<"$config_json")
  KANBOARD_USERNAME=$(jq -r '.username' <<<"$config_json")
  KANBOARD_API_TOKEN=$(jq -r '.apiToken' <<<"$config_json")
}

load_config

if ! command -v curl >/dev/null 2>&1; then
  echo "Error: curl is required." >&2
  exit 1
fi

TMP_DIR=$(mktemp -d "${TMPDIR:-/tmp}/kanboard-md.XXXXXX")
trap 'rm -rf "$TMP_DIR"' EXIT

rpc() {
  local method=$1
  local params=$2
  local destination=$3
  local request_file="$TMP_DIR/request.json"
  local response_file="$TMP_DIR/response.json"

  jq -n \
    --arg method "$method" \
    --argjson params "$params" \
    '{jsonrpc: "2.0", method: $method, id: 1, params: $params}' \
    >"$request_file"

  curl -fsS \
    -u "$KANBOARD_USERNAME:$KANBOARD_API_TOKEN" \
    -H "Content-Type: application/json" \
    --data-binary "@$request_file" \
    "${KANBOARD_URL%/}/jsonrpc.php" \
    >"$response_file"

  if ! jq -e 'has("result") and (.error == null)' "$response_file" >/dev/null; then
    echo "Kanboard API error in $method:" >&2
    jq -r 'if .error then (.error.message // (.error | tostring)) else "Invalid JSON-RPC response" end' \
      "$response_file" >&2
    exit 1
  fi

  jq '.result' "$response_file" >"$destination"
}

export_boards() {
  local method=getMyProjects

  if [[ "$KANBOARD_USERNAME" == "jsonrpc" ]]; then
    method=getAllProjects
  fi

  rpc "$method" '{}' "$TMP_DIR/projects.json"

  jq -nr \
    --slurpfile projects "$TMP_DIR/projects.json" '
      def text:
        if . == null then "" else tostring | gsub("[\\r\\n]+"; " ") end;

      def inline_text:
        text | gsub("(?<char>[\\\\`*_{}\\[\\]()<>#+.!|~-])"; "\\\(.char)");

      def link_url:
        text
        | gsub("\\\\"; "%5C")
        | gsub(" "; "%20")
        | gsub("<"; "%3C")
        | gsub(">"; "%3E");

      def items:
        if type == "array" then . else [] end;

      def board_link:
        "- #" + (.id | text) + " " +
        (if (.url.board // "") != "" then
          "[" + (.name | inline_text) + "](<" + (.url.board | link_url) + ">)"
         else .name | inline_text end) +
        (if (.identifier // "") != "" then " (" + (.identifier | inline_text) + ")" else "" end);

      ($projects[0] | items | sort_by(.id | tonumber)) as $all |
      ([$all[] | select((.is_active | tostring) == "1")]) as $active |
      ([$all[] | select((.is_active | tostring) != "1")]) as $inactive |

      "# Boards",
      "",
      "## 有効 (" + ($active | length | tostring) + ")",
      "",
      (if ($active | length) == 0 then "_ボードなし_" else ($active[] | board_link) end),
      "",
      "## 無効 (" + ($inactive | length | tostring) + ")",
      "",
      (if ($inactive | length) == 0 then "_ボードなし_" else ($inactive[] | board_link) end),
      ""
    '
}

export_board() {
  local board_id=$1
  local params

  params=$(jq -cn --argjson project_id "$board_id" '{project_id: $project_id}')
  rpc "getProjectById" "$params" "$TMP_DIR/project.json"
  rpc "getBoard" "$params" "$TMP_DIR/board.json"

  jq -nr \
    --slurpfile project "$TMP_DIR/project.json" \
    --slurpfile board "$TMP_DIR/board.json" '
      def text:
        if . == null then "" else tostring | gsub("[\\r\\n]+"; " ") end;

      def inline_text:
        text | gsub("(?<char>[\\\\`*_{}\\[\\]()<>#+.!|~-])"; "\\\(.char)");

      def due_date:
        if . == null or . == "" or . == 0 or . == "0" then null
        elif type == "number" then strftime("%Y-%m-%d")
        elif test("^[0-9]+$") then tonumber | strftime("%Y-%m-%d")
        else text
        end;

      ($project[0]) as $p |
      ($board[0]) as $swimlanes |

      "# " + ($p.name | inline_text),
      "",
      "- プロジェクトID: " + ($p.id | text),
      "- 状態: " + (if ($p.is_active | tostring) == "1" then "有効" else "無効" end),
      (if ($p.description // "") != "" then
        "- 説明: " + ($p.description | inline_text)
       else empty end),
      "",
      ($swimlanes[] |
        . as $swimlane |
        "## " + ($swimlane.name | inline_text),
        "",
        ($swimlane.columns | sort_by(.position | tonumber)[] |
          . as $column |
          (($column.tasks // []) | sort_by(.position | tonumber)) as $column_tasks |
          "### " + ($column.title | inline_text) + " (" + ($column_tasks | length | tostring) + ")",
          (if (($column.task_limit // 0) | tonumber) > 0 then
            "",
            "タスク上限: " + ($column.task_limit | text)
           else empty end),
          "",
          (if ($column_tasks | length) == 0 then
            "_タスクなし_"
           else
            ($column_tasks[] |
              . as $task |
              ([
                (if ($task.assignee_name // "") != "" then "担当: " + ($task.assignee_name | inline_text)
                 elif ($task.assignee_username // "") != "" then "担当: " + ($task.assignee_username | inline_text)
                 else "担当: 未割り当て" end),
                (if ($task.category_name // "") != "" then "カテゴリ: " + ($task.category_name | inline_text) else empty end),
                (($task.date_due | due_date) as $due | if $due then "期限: " + $due else empty end),
                (if ($task.score // 0 | tonumber) > 0 then "複雑度: " + ($task.score | text) else empty end)
              ] | join(" / ")) as $meta |
              "- #" + ($task.id | text) + " " + ($task.title | inline_text) +
              (if $meta != "" then " — " + $meta else "" end)
            )
          end),
          ""
        )
      )
    '
}

export_task() {
  local task_id=$1
  local task_params
  local project_id
  local project_params

  task_params=$(jq -cn --argjson task_id "$task_id" '{task_id: $task_id}')
  rpc "getTask" "$task_params" "$TMP_DIR/task.json"

  if ! jq -e 'type == "object"' "$TMP_DIR/task.json" >/dev/null; then
    echo "Error: task $task_id was not found." >&2
    exit 1
  fi

  project_id=$(jq -r '.project_id' "$TMP_DIR/task.json")
  project_params=$(jq -cn --argjson project_id "$project_id" '{project_id: $project_id}')

  rpc "getProjectById" "$project_params" "$TMP_DIR/project.json"
  rpc "getBoard" "$project_params" "$TMP_DIR/board.json"
  rpc "getAllSubtasks" "$task_params" "$TMP_DIR/subtasks.json"
  rpc "getAllComments" "$task_params" "$TMP_DIR/comments.json"

  jq -nr \
    --arg task_id "$task_id" \
    --slurpfile task "$TMP_DIR/task.json" \
    --slurpfile project "$TMP_DIR/project.json" \
    --slurpfile board "$TMP_DIR/board.json" \
    --slurpfile subtasks "$TMP_DIR/subtasks.json" \
    --slurpfile comments "$TMP_DIR/comments.json" '
      def text:
        if . == null then "" else tostring | gsub("[\\r\\n]+"; " ") end;

      def inline_text:
        text | gsub("(?<char>[\\\\`*_{}\\[\\]()<>#+.!|~-])"; "\\\(.char)");

      def link_url:
        text
        | gsub("\\\\"; "%5C")
        | gsub(" "; "%20")
        | gsub("<"; "%3C")
        | gsub(">"; "%3E");

      def markdown:
        if . == null then "" else tostring | gsub("\\r\\n"; "\n") | gsub("\\r"; "\n") end;

      def present:
        . != null and . != "" and . != 0 and . != "0";

      def timestamp:
        if present then tonumber | strftime("%Y-%m-%d %H:%M UTC") else null end;

      def items:
        if type == "array" then . else [] end;

      ($task[0]) as $t |
      ($project[0]) as $p |
      ($subtasks[0] | items | sort_by(.position // .id | tonumber)) as $sts |
      ($comments[0] | items | sort_by(.date_creation | tonumber)) as $cs |
      ([
        $board[0][] as $swimlane |
        $swimlane.columns[] as $column |
        ($column.tasks // [])[] |
        select((.id | tostring) == $task_id) |
        . + {
          swimlane_name: $swimlane.name,
          column_name: $column.title
        }
      ] | first // {}) as $board_task |

      "# #" + ($t.id | text) + " " + ($t.title | inline_text),
      "",
      "- 状態: " + (if ($t.is_active | tostring) == "1" then "有効" else "完了" end),
      "- プロジェクト: " + ($p.name // ("ID: " + ($t.project_id | text)) | inline_text),
      "- スイムレーン: " +
        (if ($board_task.swimlane_name // "") != "" then ($board_task.swimlane_name | inline_text)
         elif ($t.swimlane_id | tostring) == "0" then ($p.default_swimlane // "Default swimlane" | inline_text)
         else "ID: " + ($t.swimlane_id | text) end),
      "- 列: " + ($board_task.column_name // ("ID: " + ($t.column_id | text)) | inline_text),
      "- 担当: " +
        (if ($board_task.assignee_name // "") != "" then ($board_task.assignee_name | inline_text)
         elif ($board_task.assignee_username // "") != "" then ($board_task.assignee_username | inline_text)
         elif ($t.owner_id | tostring) == "0" then "未割り当て"
         else "ユーザーID: " + ($t.owner_id | text) end),
      (if ($board_task.category_name // "") != "" then
        "- カテゴリ: " + ($board_task.category_name | inline_text)
       elif ($t.category_id | tostring) != "0" then
        "- カテゴリID: " + ($t.category_id | text)
       else empty end),
      (if ($t.reference // "") != "" then "- 参照: " + ($t.reference | inline_text) else empty end),
      (if ($t.priority // 0 | tonumber) > 0 then "- 優先度: " + ($t.priority | text) else empty end),
      (if ($t.score // 0 | tonumber) > 0 then "- 複雑度: " + ($t.score | text) else empty end),
      (if ($t.time_estimated // 0 | tonumber) > 0 then "- 見積時間: " + ($t.time_estimated | text) + "h" else empty end),
      (if ($t.time_spent // 0 | tonumber) > 0 then "- 作業時間: " + ($t.time_spent | text) + "h" else empty end),
      (($t.date_creation | timestamp) as $date | if $date then "- 作成: " + $date else empty end),
      (($t.date_started | timestamp) as $date | if $date then "- 開始: " + $date else empty end),
      (($t.date_due | timestamp) as $date | if $date then "- 期限: " + $date else empty end),
      (($t.date_completed | timestamp) as $date | if $date then "- 完了: " + $date else empty end),
      (if ($t.url // "") != "" then "- URL: <" + ($t.url | link_url) + ">" else empty end),
      "",
      "## 説明",
      "",
      (if ($t.description // "") != "" then ($t.description | markdown) else "_説明なし_" end),
      "",
      "## サブタスク",
      "",
      (if ($sts | length) == 0 then
        "_サブタスクなし_"
       else
        ($sts[] |
          "- [" + (if (.status | tostring) == "2" then "x" else " " end) + "] " + (.title | inline_text) +
          (if (.status | tostring) == "1" then "（進行中）" else "" end) +
          (if (.name // "") != "" then " — 担当: " + (.name | inline_text)
           elif (.username // "") != "" then " — 担当: " + (.username | inline_text)
           else "" end)
        )
      end),
      "",
      "## コメント",
      "",
      (if ($cs | length) == 0 then
        "_コメントなし_"
       else
        ($cs[] |
          "### " +
            (if (.name // "") != "" then (.name | inline_text)
             elif (.username // "") != "" then (.username | inline_text)
             else "不明なユーザー" end) +
            ((.date_creation | timestamp) as $date | if $date then " — " + $date else "" end),
          "",
          (.comment | markdown),
          ""
        )
      end)
    '
}

case "$COMMAND" in
  boards) export_boards ;;
  board) export_board "$RESOURCE_ID" ;;
  task) export_task "$RESOURCE_ID" ;;
esac
